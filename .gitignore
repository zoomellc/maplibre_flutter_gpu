# Native implementation and build tooling live in the private development
# repository. This public repository intentionally carries prebuilts only.
/vendor/
/.gitmodules
/tool/gen_abi.dart
/native/*
!/native/*.so
!/native/*.a
!/native/*.dylib

# Keep the declared shader asset directory present in clean checkouts.
!/build/
/build/*
!/build/shaderbundles/
/build/shaderbundles/*
!/build/shaderbundles/.gitkeep
